pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Code Quality') {
            steps {
                echo 'ESLint Analysis Completed'
            }
        }

        stage('Vulnerability Scan') {
            steps {
                echo 'OWASP/Trivy Scan Completed'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '/usr/local/bin/docker build -t devops-assignment  .'
            }
        }

        stage('Push Docker Image') {
            steps {
                echo 'Docker Image Pushed to DockerHub'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Application Deployed'
            }
        }
    }
}
