pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Git Version Check') {
    steps {
        sh 'git --version'
    }
}

stage('Node Check') {
    steps {
        sh 'which node'
        sh 'node -v'
        sh 'which npm'
        sh 'npm -v'
    }
}

stage('Dependency Check') {
    steps {
        sh 'npm install'
    }
}
                

        stage('Code Quality Check') {
            steps {
                sh 'npx eslint . || true'
            }
        }

        stage('Containerization') {
            steps {
                sh 'docker build -t navyashetty0402/devops-assignment:v2 .'
            }
        }

        stage('Docker Hub Push') {
            steps {
                sh 'docker push navyashetty0402/devops-assignment:v2'
            }
        }

        stage('Deployment') {
            steps {
                sh 'docker run -d -p 3000:3000 navyashetty0402/devops-assignment:v2 || true'
            }
        }
    }
}