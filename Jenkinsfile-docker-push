pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Code Quality') {
            steps {
                echo 'ESLint Analysis Completed'
            }
        }

        stage('Vulnerability Scan') {
            steps {
                echo 'OWASP/Trivy Scan Completed'
            }
        }

        stage('Build Docker Image')  {
            steps {
                sh '/usr/local/bin/docker --version'
                echo 'Docker Build Stage Completed'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deployment Stage Completed'
            }
        }

    }
}
